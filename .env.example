# Copy to .env.local and fill in.

# --- Local Postgres (docker-compose) ---
POSTGRES_USER=traceline
POSTGRES_PASSWORD=traceline_dev
POSTGRES_DB=traceline
POSTGRES_PORT=5432

# --- Local Redis (docker-compose) ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# --- FastAPI ---
API_PORT=8000
API_BASE_URL=http://localhost:8000
FASTF1_CACHE_DIR=./.fastf1-cache
# Data source for /race-data: "fastf1" or "openf1". Default openf1 because
# F1's CloudFront currently IP-blocks FastF1 (as of 2026-05).
DATA_SOURCE=openf1

# --- Next.js / frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Supabase (provision a project at https://supabase.com, then fill these) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
